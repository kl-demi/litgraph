# --- ArcadeDB backend (default) ---
GRAPH_BACKEND=arcadedb
ARCADEDB_URI=bolt://localhost:7688
ARCADEDB_HTTP_URL=http://localhost:2480
ARCADEDB_DATABASE=arxiv
ARCADEDB_USER=root
ARCADEDB_PASSWORD=changeme123

SEMANTIC_SCHOLAR_API_KEY=

EMBEDDING_MODEL_NAME=sentence-transformers/allenai-specter
EMBEDDING_DIMENSIONS=768

DEFAULT_ARXIV_CATEGORIES=cs.CL,cs.LG,cs.AI

KAGGLE_DATASET_PATH=

# --- Neo4j backend (see README) ---
# Comment out the ArcadeDB block above and uncomment this one to switch back.
